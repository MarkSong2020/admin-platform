{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "团队级权限基线（进版本库）。设计见 doc/operations/UNATTENDED_EXECUTION.md。allow = 自动放行的安全操作（减少日常弹框，无人值守可复用）；deny = 绝对红线（交互开发也不该做）。注意：普通 git push 故意不 deny（交互开发要用）；无人值守不 push 靠 supervisor 的严格 allowlist（默认拒绝）+ feature 分支物理隔离，不靠这里的 deny。deny 黑名单可被 shell 变量/别名/脚本间接调用绕过，不是唯一防线。",
  "permissions": {
    "allow": [
      "Bash(make check)",
      "Bash(make coverage)",
      "Bash(make test)",
      "Bash(make test-integration)",
      "Bash(make check-db)",
      "Bash(make smoke-generator)",
      "Bash(make schema-doc)",
      "Bash(make audit)",
      "Bash(make compose-up)",
      "Bash(make compose-up-cache)",
      "Bash(make compose-down)",
      "Bash(make new-module:*)",
      "Bash(make migration:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run pyright)",
      "Bash(uv run lint-imports)",
      "Bash(uv run alembic check)",
      "Bash(uv run alembic history:*)",
      "Bash(uv run alembic heads:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git switch -c:*)",
      "Bash(git commit:*)",
      "Bash(git add src/*)",
      "Bash(git add tests/*)",
      "Bash(git add doc/*)",
      "Bash(git add docs/*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(git add .)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -d:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash clear)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(docker push:*)"
    ]
  }
}
