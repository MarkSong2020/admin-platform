{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "团队级权限基线（进版本库）。allow = 自动放行的只读 / 本地质量门安全操作（lint / 类型 / 测试 / 分层契约 / schema 漂移 / 起停本地容器 / 生成业务域），减少日常弹框。git 写操作（commit / switch / add）与迁移生成（make migration）故意不放行——遵循 AGENTS.md「不主动 commit/push」，须由人显式授权。deny = 绝对红线（交互开发也不该做）；普通 git push 故意不 deny（交互开发要用）。deny 黑名单可被 shell 变量/别名/脚本间接调用绕过，不是唯一防线。",
  "permissions": {
    "allow": [
      "Bash(make check)",
      "Bash(make coverage)",
      "Bash(make test)",
      "Bash(make test-integration)",
      "Bash(make check-db)",
      "Bash(make smoke-generator)",
      "Bash(make schema-doc)",
      "Bash(make audit)",
      "Bash(make compose-up)",
      "Bash(make compose-up-cache)",
      "Bash(make compose-down)",
      "Bash(make new-module:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run pyright)",
      "Bash(uv run lint-imports)",
      "Bash(uv run alembic check)",
      "Bash(uv run alembic history:*)",
      "Bash(uv run alembic heads:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(git add .)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -d:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash clear)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(docker push:*)"
    ]
  }
}
