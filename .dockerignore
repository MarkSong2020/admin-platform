# VCS / IDE / agent settings
.git/
.github/
.idea/
.vscode/
.claude/

# Tool caches and venv
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.uv-cache/

# Build artifacts
dist/
build/
*.egg-info/

# Python runtime
**/__pycache__/
**/*.py[cod]
**/*$py.class

# Tests and docs (not needed in runtime image)
tests/
docs/

# Env / secrets — 排除所有 .env 变体（含 .env.production/.env.staging），防 remote BuildKit
# 收到 build context 时泄漏密钥；仅放行无密钥的 .env.example 模板。
.env*
!.env.example

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
