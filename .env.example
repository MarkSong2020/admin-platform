# Local dev only. Production loads from env vars (Errata #4: official source priority).
# Copy to .env and adjust. Never commit .env.
# All keys are namespaced with APP_ to avoid collision with platform env.
#
# 完整字段 schema 见 src/admin_platform/core/config.py:Settings；
# 字段命名 / env_prefix / 边界含义见 doc/standards/NAMING_CONVENTIONS.md。
# tests/unit/test_config.py::test_env_example_covers_all_settings_fields
# 守门 .env.example 与 Settings 不漂移。

# Application
APP_APP_NAME=admin-platform
APP_SERVICE_ID=admin_platform
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# Middleware
APP_REQUEST_ID_HEADER=X-Request-ID

# CORS — JSON array. Empty list disables CORS middleware.
# Wildcard "*" is rejected when APP_CORS_ALLOW_CREDENTIALS=true.
APP_CORS_ALLOW_ORIGINS=[]
APP_CORS_ALLOW_CREDENTIALS=true

# Database (Phase C). Production must override via platform env.
APP_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app
APP_DB_ECHO=false
APP_DB_POOL_SIZE=5
APP_DB_MAX_OVERFLOW=10

# Idempotency-Key (ADR §11) — Redis-backed POST 幂等
# enabled=true 时 /readyz 会探测 Redis；本地不跑 Redis 则改成 false。
APP_IDEMPOTENCY_ENABLED=true
APP_REDIS_URL=redis://localhost:6379/0
# 24h 默认；< 60s 直接被 Settings 拒绝（重试窗口短到等于关闭幂等）。
APP_IDEMPOTENCY_TTL_SECONDS=86400
# In-flight SET NX lock TTL，bounded 5..3600；详 DEPLOYMENT.md 的 sizing 段。
APP_IDEMPOTENCY_LOCK_TTL_SECONDS=30

# Startup
# 生产建议 true：lifespan 启动时 eager-probe DB + Redis，连不上直接 exit；
# 默认 false 是 back-compat，依赖懒连接 + /readyz 轮询发现外联故障。
APP_STARTUP_EAGER_CONNECT=false

# OpenTelemetry (ADR §4)
# 默认关闭；生产设 APP_OTEL_ENABLED=true + OTEL_EXPORTER_OTLP_ENDPOINT
APP_OTEL_ENABLED=false
# exporter endpoint / service name 走标准 OTel env vars:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=my-service

# JWT Bearer Auth (ADR §5)
# 默认关闭（向后兼容）。生产开启后，所有非公开路径都必须带有效 JWT。
APP_AUTH_ENABLED=false
# HMAC shared secret 或 RSA/EC public key PEM
APP_AUTH_JWT_SECRET=
APP_AUTH_JWT_ALGORITHM=HS256
# iss/aud 校验默认不启用 —— 等团队 SSO 上线 + Q4 决议后配置
APP_AUTH_JWT_ISSUER=
APP_AUTH_JWT_AUDIENCE=
# 无需 token 的公开路径（JSON 数组），默认含 health / docs / openapi
# ⚠️ 此值会**覆盖** Settings 默认公开路径 —— 必须含 auth 端点，否则启用 auth 后登录被中间件拦死。
APP_AUTH_PUBLIC_PATHS='["/healthz","/startupz","/readyz","/docs","/openapi.json","/api/v1/auth/login","/api/v1/auth/refresh","/api/v1/auth/logout","/api/v1/auth/captcha"]'
# access token 存活时长（秒），默认 2h。P0 只发 access token、不做 refresh
APP_AUTH_ACCESS_TOKEN_TTL_SECONDS=7200
# P1.4 refresh token（opaque + HMAC 落库可撤销）。pepper 独立于 jwt_secret，空时签发/校验 fail-fast
APP_AUTH_REFRESH_TOKEN_PEPPER=
# refresh token 双 TTL（秒）：idle 滑动续期 7d / absolute 硬上限 30d
APP_AUTH_REFRESH_IDLE_TTL_SECONDS=604800
APP_AUTH_REFRESH_ABSOLUTE_TTL_SECONDS=2592000
# 并发登录上限（family 数）。⚠️ 数值待确认（decision-log 2026-06-09 §3）
APP_AUTH_REFRESH_MAX_SESSIONS_PER_USER=5
# 登录防护总开关（验证码 + 限流），独立于 idempotency（Codex 深审解耦：关幂等不再静默关防护）。
# ⚠️ 生产开 auth 强烈建议同开 + 配 Redis + APP_STARTUP_EAGER_CONNECT=true（不可达则 startup fail-fast）。
APP_AUTH_LOGIN_GUARD_ENABLED=false
# P1.4 验证码 + 登录限流（依赖 Redis）。验证码 TTL 秒
APP_AUTH_CAPTCHA_TTL_SECONDS=120
# 登录失败限流：窗口/要求验证码阈值/软锁阈值/软锁时长/IP 上限。⚠️ 数值待确认（decision-log §3）
APP_AUTH_LOGIN_FAIL_WINDOW_SECONDS=600
APP_AUTH_LOGIN_CAPTCHA_THRESHOLD=3
APP_AUTH_LOGIN_LOCK_THRESHOLD=5
APP_AUTH_LOGIN_LOCK_SECONDS=600
APP_AUTH_LOGIN_IP_LIMIT=30

# P2 审计/登录日志的客户端 IP 取值。false=取直连 peer（不可伪造）；true=取 X-Forwarded-For
# 最左跳，⚠️ 仅在可信反代覆盖/剥离客户端自带 XFF 时才可开（否则 IP 可伪造，污染审计/限流）。
APP_AUDIT_TRUST_X_FORWARDED_FOR=false
